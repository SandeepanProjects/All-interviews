## ✅ 1. Retry + Backoff

```swift
func retry<T>(
    times: Int,
    operation: @escaping () async throws -> T
) async throws -> T {
    var lastError: Error?

    for _ in 0..<times {
        do {
            return try await operation()
        } catch {
            lastError = error
        }
    }
    throw lastError!
}
```

---

## ✅ 2. Request Deduplication (Actor)

```swift
actor RequestDeduplicator {
    private var ongoing: Task<[User], Error>?

    func run(_ block: @escaping () async throws -> [User]) async throws -> [User] {
        if let task = ongoing {
            return try await task.value
        }

        let task = Task { try await block() }
        ongoing = task

        defer { ongoing = nil }

        return try await task.value
    }
}
```

