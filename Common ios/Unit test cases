# ✅ 3. Async Concurrency Test (Important for Senior Roles)

### 🔹 Example: Prevent Duplicate API Calls

```swift
actor RequestManager {
    private var isFetching = false

    func fetch() async -> Bool {
        if isFetching { return false }
        isFetching = true

        try? await Task.sleep(nanoseconds: 1_000_000_000)

        isFetching = false
        return true
    }
}
```

---

### 🔹 Unit Test

```swift
final class RequestManagerTests: XCTestCase {

    func test_preventDuplicateRequests() async {
        let manager = RequestManager()

        async let first = manager.fetch()
        async let second = manager.fetch()

        let results = await [first, second]

        XCTAssertTrue(results.contains(true))
        XCTAssertTrue(results.contains(false))
    }
}
```

