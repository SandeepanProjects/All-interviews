        let mockService = MockAuthService()
        let viewModel = LoginViewModel(service: mockService)

        let result = await viewModel.login(email: "test@test.com", password: "123456")

        switch result {
        case .success(let user):
            XCTAssertEqual(user.name, "Test")
        case .failure:
            XCTFail("Expected success")
        }
    }

    func test_login_invalidInput() async {
        let mockService = MockAuthService()
        let viewModel = LoginViewModel(service: mockService)

        let result = await viewModel.login(email: "invalid", password: "123")

        switch result {
        case .success:
            XCTFail("Expected failure")
        case .failure(let error):
            XCTAssertEqual(error as? LoginError, .invalidInput)
        }
    }

    func test_login_failure() async {
        let mockService = MockAuthService()
        mockService.shouldFail = true
        let viewModel = LoginViewModel(service: mockService)

        let result = await viewModel.login(email: "test@test.com", password: "123456")

        switch result {
        case .success:
            XCTFail("Expected failure")
        case .failure(let error):
            XCTAssertEqual(error as? LoginError, .network)
        }
    }
}
