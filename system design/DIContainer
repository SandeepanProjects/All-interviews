# 🔹 5. DI Container (Production Style)

```swift
class DIContainer {
    static let shared = DIContainer()
    
    private var factories: [String: () -> Any] = [:]
    
    func register<T>(_ type: T.Type, factory: @escaping () -> T) {
        factories["\(type)"] = factory
    }
    
    func resolve<T>(_ type: T.Type) -> T {
        guard let factory = factories["\(type)"],
              let service = factory() as? T else {
            fatalError("Dependency not found: \(type)")
        }
        return service
    }
}
```

---

# 🔹 6. Dependency Registration (App Startup)

```swift
let container = DIContainer.shared

// Services
container.register(NetworkService.self) {
    URLSessionNetworkService()
}

container.register(CacheService.self) {
    UserDefaultsCacheService()
}

// Repository
container.register(UserRepository.self) {
    UserRepositoryImpl(
        network: container.resolve(NetworkService.self),
        cache: container.resolve(CacheService.self)
    )
}

// ViewModel
container.register(UserViewModel.self) {
    UserViewModel(
        repository: container.resolve(UserRepository.self)
    )
}
```

