# 🔹 7. View (SwiftUI Example)

```swift
struct UserView: View {
    @StateObject private var viewModel =
        DIContainer.shared.resolve(UserViewModel.self)
    
    var body: some View {
        List(viewModel.users, id: \.id) {
            Text($0.name)
        }
        .task {
            await viewModel.loadUsers()
        }
    }
}
```

