# 🔹 1. Network Layer

### Protocol (important for DI)

```swift
protocol NetworkService {
    func request<T: Decodable>(_ endpoint: URL) async throws -> T
}
```

### Implementation

```swift
class URLSessionNetworkService: NetworkService {
    func request<T: Decodable>(_ endpoint: URL) async throws -> T {
        let (data, _) = try await URLSession.shared.data(from: endpoint)
        return try JSONDecoder().decode(T.self, from: data)
    }
}
```

---

# 🔹 2. Cache Layer

### Protocol

```swift
protocol CacheService {
    func save<T: Encodable>(_ value: T, forKey key: String)
    func load<T: Decodable>(_ type: T.Type, forKey key: String) -> T?
}
```

### Implementation

```swift
class UserDefaultsCacheService: CacheService {
    func save<T>(_ value: T, forKey key: String) where T : Encodable {
        let data = try? JSONEncoder().encode(value)
        UserDefaults.standard.set(data, forKey: key)
    }

    func load<T>(_ type: T.Type, forKey key: String) -> T? where T : Decodable {
        guard let data = UserDefaults.standard.data(forKey: key) else { return nil }
        return try? JSONDecoder().decode(T.self, from: data)
    }
}
```

