# 🔹 Real-World Example (Clean MVVM)

```swift
protocol APIService {
    func fetchUsers()
}

class APIServiceImpl: APIService {
    func fetchUsers() { }
}

class UserViewModel {
    private let apiService: APIService
    
    init(apiService: APIService) {
        self.apiService = apiService
    }
}
```

Assembly:

```swift
container.register(APIService.self) {
    APIServiceImpl()
}

container.register(UserViewModel.self) {
    UserViewModel(apiService: container.resolve(APIService.self))
}
```

