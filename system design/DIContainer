# 🔹 3. Repository Layer (Core of Clean Architecture)

👉 Combines **network + cache**

```swift
struct User: Codable {
    let id: Int
    let name: String
}
```

### Protocol

```swift
protocol UserRepository {
    func fetchUsers() async throws -> [User]
}
```

### Implementation

```swift
class UserRepositoryImpl: UserRepository {
    private let network: NetworkService
    private let cache: CacheService
    
    init(network: NetworkService, cache: CacheService) {
        self.network = network
        self.cache = cache
    }
    
    func fetchUsers() async throws -> [User] {
        let cacheKey = "users"
        
        // 1. Try cache first
        if let cached: [User] = cache.load([User].self, forKey: cacheKey) {
            return cached
        }
        
        // 2. Fetch from network
        let url = URL(string: "https://api.example.com/users")!
        let users: [User] = try await network.request(url)
        
        // 3. Save to cache
        cache.save(users, forKey: cacheKey)
        
        return users
    }
}
```

