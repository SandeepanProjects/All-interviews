# 🔄 Auth Service (Core Brain)

```swift
enum AuthError: Error {
    case unauthorized
    case refreshFailed
}

final class AuthService {
    
    static let shared = AuthService()
    
    private let keychain = KeychainManager.shared
    
    private let accessKey = "access_token"
    private let refreshKey = "refresh_token"
    
    // MARK: - Login
    func login(username: String, password: String) async throws {
        var request = URLRequest(url: URL(string: "https://api.yourapp.com/login")!)
        request.httpMethod = "POST"
        request.httpBody = try JSONEncoder().encode([
            "username": username,
            "password": password
        ])
        
        let response: AuthResponse = try await APIClient.shared.request(endpoint: request)
        
        keychain.save(key: accessKey, value: response.accessToken)
        keychain.save(key: refreshKey, value: response.refreshToken)
    }
    
    // MARK: - Get Access Token
    func getValidAccessToken() async throws -> String {
        if let token = keychain.read(key: accessKey) {
            return token
        }
        return try await refreshToken()
    }
    
    // MARK: - Refresh Token
    func refreshToken() async throws -> String {
        guard let refresh = keychain.read(key: refreshKey) else {
            throw AuthError.refreshFailed
        }
        
        var request = URLRequest(url: URL(string: "https://api.yourapp.com/refresh")!)
        request.httpMethod = "POST"
        request.httpBody = try JSONEncoder().encode([
            "refreshToken": refresh
        ])
        
        let response: AuthResponse = try await APIClient.shared.request(endpoint: request)
        
        keychain.save(key: accessKey, value: response.accessToken)
        keychain.save(key: refreshKey, value: response.refreshToken)
        
        return response.accessToken
    }
    
    // MARK: - Logout
    func logout() {
        keychain.delete(key: accessKey)
        keychain.delete(key: refreshKey)
    }
}
```

